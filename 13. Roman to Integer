class Solution {
    public int romanToInt(String s) {
        int result = 0;
        int prev = 0;

        for (int i = s.length() - 1; i >= 0; i--) {
            int curr = valueOf(s.charAt(i));
            int sign = 1 + ((curr - prev) >> 31 << 1);
            result += sign * curr;
            prev = curr;
        }
        return result;
    }
    private int valueOf(char c) {
        return  (c == 'I') ? 1    :
                (c == 'V') ? 5    :
                (c == 'X') ? 10   :
                (c == 'L') ? 50   :
                (c == 'C') ? 100  :
                (c == 'D') ? 500  : 1000;
    }
}
